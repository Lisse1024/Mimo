{
  "$schema": "../gen/schemas/desktop-schema.json",
  "productName": "Mimo",
  "version": "0.1.0",
  "identifier": "com.lisse1024.mimo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mimo",
        "width": 320,
        "height": 460,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon-256.png"
    ]
  }
}
